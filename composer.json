{
  "name": "jord-jd/omega-search",
  "description": "Search allows you to easily add an intelligent search engine to your website or web application.",
  "type": "library",
  "authors": [
    {
      "name": "Jordan Hall",
      "email": "jordan@hall05.co.uk"
    }
  ],
  "require": {
    "php": ">=7.1",
    "jord-jd/uxdm": "^6.2",
    "illuminate/support": "^5.1 || ^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0",
    "psr/cache": "^1.0 || ^2.0 || ^3.0",
    "ext-pdo": "*"
  },
  "autoload": {
    "psr-4": {
      "JordJD\\OmegaSearch\\": "src/"
    }
  },
  "license": "LGPL-3.0-only",
  "replace": {
    "divineomega/omega-search": "self.version"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "5.1-dev"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^7.5 || ^9.6 || ^12.0"
  }
}
